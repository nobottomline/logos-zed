{
  "grammars": [
    {
      "name": "logos",
      "camelcase": "Logos",
      "scope": "source.logos",
      "file-types": [
        "x",
        "xm",
        "xi",
        "xmi"
      ],
      "injection-regex": "^logos$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A Tree-sitter Objective-C/C grammar extended with Theos Logos syntax.",
    "authors": [
      {
        "name": "Great Love (nobottomline)"
      }
    ]
  },
  "bindings": {
    "c": true,
    "node": true
  }
}
